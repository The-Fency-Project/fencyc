use main::Person;

module libc {
    pub extern func malloc(n: uint) -> ptr;
    pub extern func free(p: ptr);
}

#[heap]
struct Person {
    name: str
    pub age: uint
}

impl Person {
    pub func new_person(name: str, age: uint) -> h_Person {
        let s   = sizeof @s_Person;
        let pt  = libc::malloc(s);
        let res = pt$h_Person;
        res.name = name;
        res.age = age;
        return res;
    }
}

// TODO
pub trait Drop<T> {
    pub func drop(self: *T) {}
}

impl Drop for Person {
    pub func drop(self: *Person) {
        printintrin self.name;
        return;
    }
}

func main() { 
    let p = Person::new_person("John", 69u);
    let p2 = Person::new_person("NotJohn", 67u);
    let p3 = p2;

    printintrin p.age;

    #[target(amd64_win)] {
        printintrin "Hi windows (i hate windows)";
        hiwin();
    }

    let a = "abc";
    if a[0u] == ('a')$ubyte {
        printintrin 1;
    } else {
        printintrin 0;
    }

    if a == "abc" {
        printintrin 1;
    }

    return;
}

#[target(amd64_win)] func hiwin() {
    printintrin "hello windows";
    return;
}
