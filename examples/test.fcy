use main::Person;

module libc {
    pub extern func malloc(n: uint) -> ptr;
    pub extern func free(p: ptr);
}

#[heap]
struct Person {
    name: str
    pub age: uint
}

impl Person {
    pub func new_person(name: str, age: uint) -> h_Person {
        let s   = sizeof @s_Person;
        let pt  = libc::malloc(s);
        let res = pt$h_Person;
        res.name = name;
        res.age = age;
        return res;
    }
}

// TODO
pub trait Drop<T: [Iter], E: [Abc]> {
    pub func drop(self: *T) {}
}

impl Drop for Person {
    pub func drop(self: *Person) {
        printintrin self.name;
        return;
    }
}

func main() { 
    let p = Person::new_person("John", 69u);
    let p2 = Person::new_person("NotJohn", 67u);
    let p3 = p2;

    printintrin p.age;

    return;
}
