use main::Person;

module libc {
    pub extern func malloc(n: uint) -> ptr;
    pub extern func free(p: ptr);
}

#[heap]
struct Person {
    name: str
    pub age: uint
}

impl Person {
    pub func new_person(name: str, age: uint) -> h_Person {
        let s   = sizeof @s_Person;
        let pt  = libc::malloc(s);
        let res = pt$h_Person;
        res.name = name;
        res.age = age;
        return res;
    }
}

pub trait Drop<T> {
    pub func drop(self: *T);
}

impl Drop for Person {
    pub func drop(self: *Person) {
        printintrin self.name;
        return;
    }
}

pub trait Printable<T> {
    pub func printable(self: *T);
}

impl Printable for Person {
    pub func printable(self: *Person) {
        printintrin self.name;
        printintrin self.age;

        return;
    }
}

pub trait GetAge<T> {
    pub func getAge(self: *T) -> uint;
}

impl GetAge for Person {
    pub func getAge(self: *Person) -> uint {
        return self.age;
    }
}

pub func print<T: [Printable, GetAge], B: [GetAge]>(s: *T, s2: *B) {
    s.printable();

    let a = s.getAge() + s2.getAge();
    printintrin a;

    return;
}

func main(argc: uint, argv: [str]) -> int { 
    let p = Person::new_person("John", 69u);
    let p2 = Person::new_person("NotJohn", 67u);

    print(p, p2);

    let a = "abc";
    if a[0u] == ('a')$ubyte {
        printintrin 1;
    } else {
        printintrin 0;
    }

    let b = 1322uh; // ushort 

    return 0;
}
