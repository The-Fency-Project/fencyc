pub extern func malloc(n: uint) -> ptr;

struct Person {
    name: str 
}

impl Person {
    pub func new_person(name: str) -> h_Person {
        let s   = sizeof @s_Person;
        let pt  = main::malloc(s);
        let res = pt$h_Person;
        res.name = name;
        return res;
    }
}

func main() {
    let p = main::Person::new_person("John");

    printintrin p.name;

    return;
}
