use main::Person;

module libc {
    pub extern func malloc(n: uint) -> ptr;
    pub extern func free(p: ptr);
    pub extern func memcpy(dst: ptr, src: ptr, n: uint);
}

module std {
    module mem {
        pub trait Clone<T> {
            pub func clone(self: *T) -> *T;
        }

        pub trait Drop<T> {
            pub func drop(self: *T);
        }

        pub trait Copy<T: [Clone]> {
        }
    }
}

struct Person {
    name: str
    pub age: uint
    pub someints: [int; 3u]
}

struct Superman {
    pub p: s_Person
    pub ability_id: uint
}

impl Person {
    pub func new_person(name: str, age: uint) -> h_Person {
        let s   = sizeof @s_Person;
        let pt  = libc::malloc(s);
        let res = pt$h_Person;
        res.name = name;
        res.age = age;
        return res;
    }

    pub func new_stack_person(name: str, age: uint) -> s_Person {
        let res = main::Person {
            name: name;
            age: age;
            someints: [0, 1, 2]int;
        };

        return res;
    }
}

impl std::mem::Clone for Person {
    pub func clone(self: *Person) -> h_Person {
        let p2 = main::Person::new_person("", 0u);
        libc::memcpy(p2$ptr, self$ptr, sizeof @s_Person);
        return p2;
    }
}

impl std::mem::Drop for Person {
    pub func drop(self: *Person) {
        printintrin self.name;
        return;
    }
}

impl std::mem::Copy for Person {
}

func main(argc: uint, argv: [str]) -> int { 
    let p = Person::new_person("John", 69u);
    let p2 = Person::new_person("NotJohn", 67u);
    let arr = [p, p2]h_Person;
    printintrin arr[0u].age;

    let p3s = Person {
        name: "Don";
        age: 20u;
        someints: [1, 2, 3]int;
    };

    let p4s = Person {
        name: "Ron";
        age: 21u;
        someints: [2, 3, 4]int;
    };

    let arr2 = [p3s, *(p4s.clone())]s_Person;

    printintrin p4s.age; // 21 
    printintrin arr2[1u].age; // 21

    let p5s = Person {
        name: "Idk";
        age: 22u;
        someints: [3, 4, 5]int;
    };

    p5s.someints[2u] = 7;
    printintrin p5s.someints[2u];

    arr2[0u] = *p5s.clone();
    printintrin arr2[0u].age; // 22
    p5s.age = 55u;


    let p_sm = Person {
        name: "R.R. III"; // reference
        age: 31u;
        someints: [1, 1, 1]int;
    };

    let sm = Superman {
        p: p_sm;
        ability_id: 1u;
    };

    sm.p = p4s;

    printintrin sm.p.age;

    let p6s = Person::new_stack_person("Stack", 30u);
    printintrin p6s.age;

    return 0;
}
