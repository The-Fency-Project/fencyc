struct first {
    ptr: *second
}

struct second {
    a: int
    b: int
    c: int
}

// Pass struct by pointer 
// So you may modify original struct here
func print_both(s: *second) -> *second {
    printintrin s.a;
    s.b = 289;
    printintrin s.b;

    return s;
}

extern func malloc(n: uint) -> ptr;
func print_h(s: h_second) {
    printintrin s.b;

    return;
}

func main() {
    let test: s_second = second {
        a: 5;
        b: 4;
        c: 11; 
    };

    test.c = 12;

    print_both(&test); // would change b to 289 btw

    let test2: *first = &first {
        ptr: &test;
    };

    printintrin test2.ptr.a;

    // TODO: sizeof intrin
    let test3_ptr: ptr = malloc(24u);
    let test3: h_second = test3_ptr$h_second;
    test3.a = 15;
    test3.b = 16;
    test3.c = 17;
    print_h(test3);

    return;
}
