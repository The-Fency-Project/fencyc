use main::Person;

module libc {
    pub extern func malloc(n: uint) -> ptr;
    pub extern func realloc(p: ptr, n: uint) -> ptr;
    pub extern func free(p: ptr);
    pub extern func memcpy(dst: ptr, src: ptr, n: uint);
    pub extern func abort();
}

module std {
    module mem {
        pub trait Clone<T> {
            pub func clone(self: *T) -> *T;
        }

        pub trait Drop<T> {
            pub func drop(self: *T);
        }
    }
}

struct Person {
    name: str
    pub age: uint
}

impl Person {
    pub func new_person(name: str, age: uint) -> h_Person {
        let s   = sizeof @s_Person;
        let pt  = libc::malloc(s);
        let res = pt$h_Person;
        res.name = name;
        res.age = age;
        return res;
    }
}

impl std::mem::Clone for Person {
    pub func clone(self: *Person) -> h_Person {
        let p2 = main::Person::new_person("", 0u);
        libc::memcpy(p2$ptr, self$ptr, sizeof @s_Person);
        return p2;
    }
}

impl std::mem::Drop for Person {
    pub func drop(self: *Person) {
        printintrin self.name;
        return;
    }
}

// not really generic rn
struct Vec<T> {
    pub buf: [s_Person]
    cap: uint 
    pub len: uint 
}

impl Vec<T> {
    pub func new() -> s_Vec {
        let init_cap = 16u;
        let buf = libc::malloc(init_cap * sizeof @s_main::Person);
        
        let res = main::Vec {
            buf: buf$[s_T];
            cap: init_cap;
            len: 0u;
        };
        return res;
    }

    pub func push(self: *Vec, item: s_main::Person) {
        if ((self.len + 1u) >= self.cap) {
            let new_size = self.cap * 2u;
            let new_buf = libc::realloc((self.buf)$ptr, new_size * sizeof @s_main::Person);
            self.buf = new_buf$[s_Person];
            self.cap = new_size;
        }
        self.buf[self.len] = item;
        self.len = self.len + 1u;
        return;
    }
}

impl std::mem::Drop for Vec {
    pub func drop(self: *Vec) {
        if ((self.buf)$ptr)$uint == 0u {
            return;
        }

        for let i = 0u in i < self.len; i += 1u {
            let cur = self.buf[i];
            cur.drop();
        }
        libc::free((self.buf)$ptr);

        return;
    }
}

func main(argc: uint, argv: [str]) -> int { 
    let p = Person::new_person("John", 69u);

    let vec = Vec::new();
    vec.push(*p);

    for let i = 0 in i < 17; i += 1 {
        let p2 = Person {
            name: "NotJohn";
            age: 67u + i$uint;
        };
        
        vec.push(p2);
    } 
    
    printintrin vec.len;
    printintrin vec.buf[4u].age; 

    return 0;
}
